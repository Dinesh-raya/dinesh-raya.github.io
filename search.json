---
layout: null
---
[
{% for page in site.pages %}
  {% if page.title and page.url != "/search.json" and page.url != "/" and page.url != "/404.html" %}
    {% assign content = page.content | strip_html | strip_newlines | normalize_whitespace | truncate: 2000 %}
    {% if content.size > 10 %}
  {"title":{{ page.title | jsonify }},"url":{{ page.url | jsonify }},"content":{{ content | jsonify }},"type":"page"},
    {% endif %}
  {% endif %}
{% endfor %}
{% for post in site.posts %}
  {% assign content = post.content | strip_html | strip_newlines | normalize_whitespace | truncate: 2000 %}
  {"title":{{ post.title | jsonify }},"url":{{ post.url | jsonify }},"content":{{ content | jsonify }},"type":"post"},
{% endfor %}
{}
]